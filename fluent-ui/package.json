{
  "name": "@react-typed-forms/fluent-ui",
  "version": "1.0.0",
  "description": "FluentUI v9 form controls bound to @react-typed-forms/core",
  "type": "module",
  "main": "lib/index.cjs",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    "types": "./lib/index.d.ts",
    "require": "./lib/index.cjs",
    "default": "./lib/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doolse/react-typed-forms.git"
  },
  "author": "Jolse Maginnis",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/doolse/react-typed-forms/issues"
  },
  "homepage": "https://github.com/doolse/react-typed-forms#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "typescript",
    "forms",
    "fluent-ui",
    "fluentui"
  ],
  "peerDependencies": {
    "@fluentui/react-components": "^9.69.0",
    "@react-typed-forms/core": "^4.4.0",
    "react": "^18.2.0 || ^19"
  },
  "devDependencies": {
    "@fluentui/react-components": "^9.69.0",
    "@react-typed-forms/core": "^4.4.3",
    "react": "^18.2.0 || ^19",
    "react-dom": "^18.2.0 || ^19",
    "@types/react": "^18.2.28 || ^19",
    "microbundle": "^0.15.1",
    "rimraf": "^3.0.2",
    "typescript": "^5.6.3",
    "prettier": "^3.0.3"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "rimraf ./lib/ node_modules/.cache && microbundle -f modern,cjs --no-compress --jsx React --jsxImportSource=react",
    "watch": "microbundle -f modern,cjs --no-compress --jsx React --jsxImportSource=react"
  }
}
